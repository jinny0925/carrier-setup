rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }
    function allowed() {
      return signedIn()
        && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.active == true;
    }
    function admin() {
      return allowed()
        && get(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)).data.role == "admin";
    }
    match /allowedUsers/{email} {
      // 담당자 드롭다운을 위해 허용된 사용자는 명단 전체를 읽을 수 있습니다.
      allow read: if allowed();
      allow create, update, delete: if admin();
    }
    match /scopeTemplates/{scopeKey} {
      allow read: if allowed();
      allow create, update, delete: if admin();
      match /items/{itemId} {
        allow read: if allowed();
        allow create, update, delete: if admin();
      }
    }
    match /carriers/{projectId} {
      allow read, create, update, delete: if allowed();
      // 진행 로그는 체크 항목 문서 안의 log 배열에 저장되므로 별도 규칙이 필요 없습니다.
      match /checklistItems/{itemId} {
        allow read, create, update, delete: if allowed();
      }
    }
    // 자료실의 collectionGroup("checklistItems") 조회 허용
    match /{path=**}/checklistItems/{itemId} {
      allow read: if allowed();
    }
  }
}
